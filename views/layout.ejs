<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Система регистрации входящих писем</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom style -->
    <link href="/css/style.css" rel="stylesheet">
    <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Система регистрации писем</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/letters">Письма</a>
                        </li>
                        <% if (currentUser.role_id === 3) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/letters/assigned">Мои задачи</a>
                            </li>
                        <% } %>
                        <% if (currentUser.role_id === 1) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/users">Пользователи</a>
                            </li>
                        <% } %>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-3">
                            <span class="navbar-text text-white">
                                <strong><%= currentUser.full_name %></strong> 
                                (<%= currentUser.role_id === 1 ? 'Администратор' : (currentUser.role_id === 2 ? 'Регистратор' : 'Исполнитель') %>)
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm" href="/auth/logout">Выйти</a>
                        </li>
                    </ul>
                <% } else { %>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm" href="/auth/login">Войти</a>
                        </li>
                    </ul>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <!-- System Alerts -->
        <div class="alert-container">
            <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
        </div>

        <%- body %>
    </div>

    <!-- Footer -->
    <footer class="footer mt-auto py-3 bg-light text-center text-muted">
        <div class="container">
            <span class="text-muted small">© 2026 Система регистрации входящих писем.</span>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>