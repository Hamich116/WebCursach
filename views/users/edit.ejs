<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-8 col-md-10">
        <div class="row align-items-center mb-4">
            <div class="col-md-8">
                <h1 class="h2 text-dark m-0"><i class="bi bi-person-gear text-primary me-2"></i>Настройка профиля сотрудника</h1>
                <p class="text-muted m-0">Обновите ФИО, контактные данные, смените пароль или скорректируйте роль пользователя</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="/users" class="btn btn-outline-secondary shadow-sm"><i class="bi bi-arrow-left me-1"></i> Назад к списку</a>
            </div>
        </div>

        <div class="card card-premium shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="m-0 text-dark fw-bold"><i class="bi bi-person-badge-fill me-2"></i>Редактирование профиля: <%= user.username %></h5>
            </div>
            <div class="card-body px-4 py-4">
                <form action="/users/<%= user.id %>" method="POST" class="form-premium form-user-validation">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="username" class="form-label">Имя пользователя (Логин)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person-lock text-muted"></i></span>
                                <input type="text" class="form-control bg-light" id="username" value="<%= user.username %>" readonly>
                            </div>
                            <div class="form-text text-muted">Логин сотрудника изменить нельзя</div>
                        </div>

                        <div class="col-md-6">
                            <label for="role_id" class="form-label">Роль в системе <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-shield-lock text-muted"></i></span>
                                <select class="form-select" id="role_id" name="role_id" required>
                                    <option value="1" <%= user.role_id === 1 ? 'selected' : '' %>>Администратор (admin)</option>
                                    <option value="2" <%= user.role_id === 2 ? 'selected' : '' %>>Регистратор (registrar)</option>
                                    <option value="3" <%= user.role_id === 3 ? 'selected' : '' %>>Исполнитель (executor)</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label for="full_name" class="form-label">Полное имя (ФИО сотрудника) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-card-text text-muted"></i></span>
                                <input type="text" class="form-control" id="full_name" name="full_name" value="<%= user.full_name %>" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="email" class="form-label">Адрес электронной почты <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-envelope text-muted"></i></span>
                                <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="is_active" class="form-label">Статус учетной записи <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-toggle-on text-muted"></i></span>
                                <select class="form-select" id="is_active" name="is_active" required>
                                    <option value="true" <%= user.is_active ? 'selected' : '' %>>Активен</option>
                                    <option value="false" <%= !user.is_active ? 'selected' : '' %>>Заблокирован</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-12 mt-4 pt-3 border-top">
                            <h6 class="text-dark fw-bold mb-2"><i class="bi bi-shield-key-fill text-warning me-2"></i>Безопасность (Изменение пароля)</h6>
                            <p class="text-muted small">Оставьте поля пустыми, если не планируете менять пароль сотрудника</p>
                        </div>

                        <div class="col-md-6">
                            <label for="password" class="form-label">Новый пароль</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key text-muted"></i></span>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Оставьте пустым или от 6 симв.">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="confirm_password" class="form-label">Подтверждение нового пароля</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key-fill text-muted"></i></span>
                                <input type="password" class="form-control" id="confirm_password" placeholder="Повторите новый пароль">
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2.5 shadow-sm fw-bold"><i class="bi bi-check-circle me-1"></i> Сохранить изменения</button>
                        <a href="/users" class="btn btn-outline-secondary px-4 py-2.5">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>