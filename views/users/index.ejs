<div class="row align-items-center mb-4 animate-fade-in">
    <div class="col-md-6">
        <h1 class="h2 text-dark m-0"><i class="bi bi-people-fill text-primary me-2"></i>Управление сотрудниками</h1>
        <p class="text-muted m-0">Администрирование учетных записей, ролей и прав доступа пользователей системы</p>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <a href="/users/create" class="btn btn-primary shadow-sm"><i class="bi bi-person-plus-fill me-1"></i> Добавить сотрудника</a>
    </div>
</div>

<div class="card card-premium shadow-sm animate-fade-in">
    <div class="card-header bg-white py-3">
        <h5 class="m-0 text-dark fw-bold"><i class="bi bi-person-workspace me-2"></i>Зарегистрированные пользователи</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-premium m-0">
                <thead>
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th style="width: 15%">Имя пользователя</th>
                        <th style="width: 25%">Полное имя (ФИО)</th>
                        <th style="width: 20%">Эл. почта</th>
                        <th style="width: 10%">Роль</th>
                        <th style="width: 10%">Статус</th>
                        <th style="width: 15%">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users && users.length > 0) { %>
                        <% users.forEach(function(user) { %>
                            <tr class="animate-fade-in">
                                <td><%= user.id %></td>
                                <td class="fw-bold"><%= user.username %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar-sm me-2 bg-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.85rem; font-weight: bold;">
                                            <%= user.full_name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <strong><%= user.full_name %></strong>
                                        </div>
                                    </div>
                                </td>
                                <td><a href="mailto:<%= user.email %>" class="text-decoration-none text-muted"><%= user.email %></a></td>
                                <td>
                                    <% 
                                        const role = roles.find(function(r) { return r.id === user.role_id; }); 
                                        let roleBadge = 'bg-secondary';
                                        let roleName = role ? role.name : 'Неизвестно';
                                        
                                        if (user.role_id === 1) { roleBadge = 'bg-danger'; roleName = 'Администратор'; }
                                        else if (user.role_id === 2) { roleBadge = 'bg-primary'; roleName = 'Регистратор'; }
                                        else if (user.role_id === 3) { roleBadge = 'bg-success'; roleName = 'Исполнитель'; }
                                    %>
                                    <span class="badge <%= roleBadge %> px-2 py-1"><%= roleName %></span>
                                </td>
                                <td>
                                    <span class="badge status-active-badge px-2 py-1 <%= user.is_active ? 'bg-success' : 'bg-danger' %>">
                                        <%= user.is_active ? 'Активен' : 'Заблокирован' %>
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex">
                                        <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-outline-secondary me-1" title="Изменить">
                                            <i class="bi bi-pencil"></i> Изменить
                                        </a>
                                        
                                        <% if (typeof currentUser !== 'undefined' && user.id !== currentUser.id) { %>
                                            <!-- Активация/Блокировка через AJAX -->
                                            <button class="btn btn-sm <%= user.is_active ? 'btn-outline-warning' : 'btn-outline-success' %> btn-toggle-status me-1" data-id="<%= user.id %>" title="Заблокировать/Активировать">
                                                <% if (user.is_active) { %>
                                                    <i class="bi bi-person-x"></i> Заблокировать
                                                <% } else { %>
                                                    <i class="bi bi-person-check"></i> Активировать
                                                <% } %>
                                            </button>
                                            
                                            <!-- Удаление через AJAX -->
                                            <button class="btn btn-sm btn-outline-danger btn-delete-user" data-id="<%= user.id %>" data-username="<%= user.username %>" title="Удалить аккаунт">
                                                <i class="bi bi-trash"></i> Удалить
                                            </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-2 d-block mb-2"></i>
                                Пользователи не найдены
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>