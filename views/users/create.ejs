<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-8 col-md-10">
        <div class="row align-items-center mb-4">
            <div class="col-md-8">
                <h1 class="h2 text-dark m-0"><i class="bi bi-person-plus text-primary me-2"></i>Регистрация сотрудника</h1>
                <p class="text-muted m-0">Создайте новую учетную запись и назначьте роль в системе</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="/users" class="btn btn-outline-secondary shadow-sm"><i class="bi bi-arrow-left me-1"></i> Назад к списку</a>
            </div>
        </div>

        <div class="card card-premium shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="m-0 text-dark fw-bold"><i class="bi bi-person-badge-fill me-2"></i>Анкета нового пользователя</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form action="/users" method="POST" class="form-premium form-user-validation">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="username" class="form-label">Имя пользователя (Логин) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person text-muted"></i></span>
                                <input type="text" class="form-control" id="username" name="username" placeholder="ivanov" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="role_id" class="form-label">Роль в системе <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-shield-lock text-muted"></i></span>
                                <select class="form-select" id="role_id" name="role_id" required>
                                    <option value="">Выберите роль...</option>
                                    <option value="1">Администратор (admin)</option>
                                    <option value="2">Регистратор (registrar)</option>
                                    <option value="3">Исполнитель (executor)</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label for="full_name" class="form-label">Полное имя (ФИО сотрудника) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-card-text text-muted"></i></span>
                                <input type="text" class="form-control" id="full_name" name="full_name" placeholder="Иванов Иван Иванович" required>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label for="email" class="form-label">Адрес электронной почты <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-envelope text-muted"></i></span>
                                <input type="email" class="form-control" id="email" name="email" placeholder="ivanov@example.com" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="password" class="form-label">Пароль <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key text-muted"></i></span>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Не менее 6 символов" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="confirm_password" class="form-label">Подтверждение пароля <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key-fill text-muted"></i></span>
                                <input type="password" class="form-control" id="confirm_password" placeholder="Повторите пароль" required>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2.5 shadow-sm fw-bold"><i class="bi bi-person-check-fill me-1"></i> Зарегистрировать сотрудника</button>
                        <a href="/users" class="btn btn-outline-secondary px-4 py-2.5">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>